ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ripple_dev_pwd

# PostgreSQL
POSTGRES_DSN=postgresql+psycopg://ripple:ripple_dev_pwd@postgres:5432/ripple

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
