S3_SECRET_KEY=minioadmin

# AI
AI_ROUTER_ENDPOINT=http://ai-router:8001
AI_WEAVER_MODEL=qwen2.5-72b
AI_CRITIC_MODEL=claude-haiku
AI_EMBEDDING_MODEL=bge-large-zh
