# Ripple · docker-compose 环境变量示例
# 复制此文件为 .env 并填入真实值后执行 docker compose up
#
# ⚠️  带 :? 标记的变量是必填项，留空会导致 compose 拒绝启动
# ⚠️  生产环境所有密码必须替换为强随机值（建议 openssl rand -hex 32）

# === PostgreSQL ===
PG_USER=ripple
# 必须设置 · 示例：openssl rand -hex 16
PG_PASSWORD=CHANGE_ME

# === Neo4j ===
# 必须设置 · 示例：openssl rand -hex 16
NEO4J_PASSWORD=CHANGE_ME

# === Redis ===
# 必须设置 · 示例：openssl rand -hex 16
REDIS_PASSWORD=CHANGE_ME

# === JWT ===
# 必须设置 · 至少 32 字节 · 示例：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_xxxxx

# === App ===
APP_ENV=prod
LOG_LEVEL=info

# === CORS ===
# 前端访问地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost

# === Frontend ===
# 前端监听端口（映射到宿主机）
FRONTEND_PORT=80

# === LLM API Keys（按需填写，留空跳过对应 provider）===
# RIPPLE_ZHIPU_API_KEY=
# RIPPLE_OPENAI_API_KEY=
# RIPPLE_DEEPSEEK_API_KEY=
# RIPPLE_VOLC_API_KEY=
# RIPPLE_MINIMAX_API_KEY=
