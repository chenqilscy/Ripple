# 中间件连接信息（占位 · 等老板提供后填充）
# 任何被 TODO 标记的项必须在启动前填上真实值

# === PostgreSQL ===
RIPPLE_PG_DSN=postgres://TODO_USER:TODO_PASS@TODO_HOST:5432/ripple?sslmode=require
RIPPLE_PG_MAX_CONNS=20
RIPPLE_PG_MIN_CONNS=2

# === Neo4j ===
RIPPLE_NEO4J_URI=bolt://TODO_HOST:7687
RIPPLE_NEO4J_USER=neo4j
RIPPLE_NEO4J_PASS=TODO_PASS
RIPPLE_NEO4J_DATABASE=neo4j

# === Redis ===
RIPPLE_REDIS_ADDR=TODO_HOST:6379
RIPPLE_REDIS_PASS=TODO_PASS_OR_EMPTY
RIPPLE_REDIS_DB=0

# === S3 / MinIO ===
RIPPLE_S3_ENDPOINT=TODO_HOST:9000
RIPPLE_S3_REGION=us-east-1
RIPPLE_S3_BUCKET=ripple
RIPPLE_S3_ACCESS_KEY=TODO
RIPPLE_S3_SECRET_KEY=TODO
RIPPLE_S3_USE_SSL=false

# === Auth / JWT ===
# 生产环境此值必须 ≥ 32 字节随机；开发可用 openssl rand -hex 32 生成
RIPPLE_JWT_SECRET=DEV_ONLY_REPLACE_ME_xxxxxxxxxxxxxxxxxxxx
RIPPLE_JWT_ACCESS_TTL=1h
RIPPLE_JWT_REFRESH_TTL=720h

# === Server ===
RIPPLE_HTTP_ADDR=:8000
RIPPLE_ENV=development
RIPPLE_LOG_LEVEL=debug
RIPPLE_CORS_ORIGINS=http://localhost:5173

# === AI ===
RIPPLE_WEAVER_THRESHOLD=0.78
RIPPLE_WEAVER_TOP_K=5
RIPPLE_EMBEDDING_DIM=256
