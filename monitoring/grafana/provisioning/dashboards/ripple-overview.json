{
  "title": "Ripple Overview",
  "uid": "ripple-overview-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP 请求速率 (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(ripple_http_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP p95 延迟 (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ripple_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p95 ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB 连接池 (已用/总量)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "ripple_db_pool_acquired_conns",
          "legendFormat": "acquired"
        },
        {
          "expr": "ripple_db_pool_total_conns",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LLM 调用总数",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(ripple_llm_calls_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP 请求速率（总量）",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(ripple_http_requests_total[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP 延迟分布（p50 / p95 / p99）",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ripple_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ripple_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ripple_http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB 连接池趋势",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "ripple_db_pool_acquired_conns",
          "legendFormat": "acquired"
        },
        {
          "expr": "ripple_db_pool_total_conns",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "LLM 调用速率（按 provider）",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (provider) (rate(ripple_llm_calls_total[1m]))",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
